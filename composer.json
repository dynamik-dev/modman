{
    "name": "dynamik-dev/modman",
    "description": "Headless Laravel content-moderation package with a tiered grader pipeline.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-model-states": "^2.7"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "rector/rector": "^2.0",
        "driftingly/rector-laravel": "^2.0",
        "icanhazstring/composer-unused": "^0.8|^0.9",
        "maglnet/composer-require-checker": "^4.14"
    },
    "autoload": {
        "psr-4": {
            "Dynamik\\Modman\\": "src/",
            "Dynamik\\Modman\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dynamik\\Modman\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Dynamik\\Modman\\ModmanServiceProvider"]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
